def test_ensure_freeuv_weight_missing_triggers_gdrive_download(tmp_path, monkeypatch):
    import folder_paths
    import nodes.freeuv_load as mod

    monkeypatch.setattr(folder_paths, "models_dir", str(tmp_path))
    called = {}

    def fake_download(url: str, out_dir: Path):
        called["url"] = url
        called["out_dir"] = Path(out_dir)
        Path(out_dir).mkdir(parents=True, exist_ok=True)
        (Path(out_dir) / "uv_structure_aligner.bin").write_bytes(b"stub")
        (Path(out_dir) / "flaw_tolerant_facial_detail_extractor.bin").write_bytes(b"stub")

    monkeypatch.setattr(mod, "_download_gdrive_folder", fake_download)
    path = mod._ensure_freeuv_weight("uv_structure_aligner.bin")
    assert called["url"] == mod.FREEUV_GDRIVE_FOLDER
    assert called["out_dir"] == tmp_path / "freeuv"
    assert path == tmp_path / "freeuv" / "uv_structure_aligner.bin"


